{
  "expo": {
    "name": "VitaMood",
    "slug": "VitaMood",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vitamood",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.vitamood.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#7BA68A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F7F5F2",
          "dark": {
            "backgroundColor": "#0E1014"
          }
        }
      ],
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7106488480723857~9258505589",
          "iosAppId": "ca-app-pub-0000000000000000~0000000000",
          "userTrackingPermission": "This identifier will be used to deliver personalized ads to you. Off by default — you can opt in from the Account tab."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
